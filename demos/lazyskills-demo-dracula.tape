Output demos/lazyskills-demo-dracula.gif

Require lazyskills

Set Shell "bash"
Set FontFamily "JetBrainsMono Nerd Font Mono"
Set Theme "Dracula"
Set FontSize 24
Set Width 1680
Set Height 1080
Set Framerate 60
Set TypingSpeed 40ms
Set Padding 20

Type "lazyskills"
Enter
Sleep 1800ms

Type "claude-code"
Sleep 1200ms
Space
Sleep 500ms
Down
Sleep 500ms
Enter
Sleep 1500ms

Type "3"
Sleep 700ms
Sleep 400ms
Type "/"
Sleep 500ms
Type "electron"
Sleep 2s
Escape
Sleep 600ms

Type "f"
Sleep 600ms
Type "i"
Sleep 5s
Enter
Sleep 700ms

Type "1"
Sleep 700ms
Sleep 400ms
Type "d"
Sleep 500ms
Enter
Sleep 1200ms

Type "4"
Sleep 700ms
Sleep 400ms
Type "i"
Sleep 5s
Enter
Sleep 700ms

Type "1"
Sleep 1200ms
Sleep 400ms
Type "q"
Sleep 800ms
